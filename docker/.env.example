# IGP 国际集团 — Docker 环境变量
# 复制此文件为 .env 后填入实际值

# ==== 必填：Gateway ====
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-random-secure-token
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ==== 可选：模型 Fallback ====
# ANTHROPIC_API_KEY=sk-ant-your-claude-key
# OPENAI_API_KEY=sk-proj-your-openai-key

# ==== 可选：Cloudflare Tunnel ====
CF_TUNNEL_TOKEN=
CF_API_TOKEN=

# ==== 可选：PostgreSQL ====
PG_USER=igp
PG_PASSWORD=change-me-pg-password
PG_DB=igp_memory

# ==== 部署环境 ====
COMPOSE_PROJECT_NAME=igp
