// IGP 集团 MetaMCP 聚合配置
// 由 metamcp 容器加载
//
// 启动方式: docker run -p 12008:12008 -v ./mcp/metamcp.json:/config.json metamcp/metamcp:latest

{
  "server": {
    "port": 12008,
    "host": "127.0.0.1"
  },

  "upstreams": [
    {
      "name": "github",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    {
      "name": "notion",
      "transport": "http",
      "url": "https://api.notion.com/v1/mcp",
      "headers": {
        "Notion-Version": "2022-06-28"
      }
    },
    {
      "name": "postgres",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres"],
      "env": {
        "POSTGRES_CONNECTION_STRING": "${POSTGRES_URL}"
      }
    }
  ]
}
