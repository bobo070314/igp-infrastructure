// IGP 国际集团 — Gateway 控制平面配置文件
// 基于 OpenClaw 真实 schema (docs verified 2026-07-01)
//
// 注意: OpenClaw 严格校验 schema，无效字段导致 Gateway 拒绝启动
// 所有字段均来自: docs/openclaw/docs/gateway/configuration-reference.md
//
// v0.4.0: + diagnostics (OTEL metrics), memorySearch, mcp (正式合并)

{
  // ====================================================================
  // 诊断 & 可观测性 (OTEL)
  // ====================================================================
  diagnostics: {
    enabled: true,

    otel: {
      enabled: true,
      metricsEndpoint: "http://localhost:4318/v1/metrics",
      logsEndpoint: "http://localhost:4318/v1/logs",
      protocol: "http/protobuf",
      serviceName: "igp-gateway",
      metrics: true,
      logs: false,
      sampleRate: 1.0,
      flushIntervalMs: 5000,
      captureContent: {
        enabled: false,
        inputMessages: false,
        outputMessages: false,
        toolInputs: false,
        toolOutputs: false,
        systemPrompt: false,
        toolDefinitions: false,
      },
    },
  },

  // ====================================================================
  // Agent 配置
  // ====================================================================
  agents: {
    defaults: {
      workspace: "~/.openclaw/workspace",

      // 模型配置
      model: {
        primary: "deepseek/deepseek-v4-flash",
        fallbacks: [
          "deepseek/deepseek-v3",
        ],
      },

      // 模型目录
      models: {
        "deepseek/deepseek-v4-flash": { alias: "Flash" },
        "deepseek/deepseek-v3":       { alias: "DeepThink" },
      },

      // Shell 白名单
      tools: {
        exec: {
          allow: [
            { match: { command: "ls" } },
            { match: { command: "cat" } },
            { match: { command: "head" } },
            { match: { command: "tail" } },
            { match: { command: "git", args: ["status", "diff", "log", "show"] } },
            { match: { command: "pnpm", args: ["install", "run", "build", "test"] } },
            { match: { command: "curl" } },
            { match: { command: "python" } },
            { match: { command: "docker", args: ["ps", "logs", "images"] } },
            { match: { command: "write" }, requireApproval: true },
          ],
        },
      },

      // 成本（每日 $10, 单次 $0.5）
      costLimit: {
        daily: 10,
        perRequest: 0.5,
      },

      // Memory Search — 档案馆
      memorySearch: {
        enabled: true,
        extraPaths: [
          "./agents/shared/memory",
        ],
        sources: ["memory"],
        query: {
          hybrid: {
            enabled: true,
            vectorWeight: 0.7,
            textWeight: 0.3,
          },
        },
      },
    },

    // 子公司（Multi-Agent）
    list: [
      {
        id: "coding",
        name: "研发部",
        default: true,
        workspace: "~/.openclaw/workspace-coding",
      },
      {
        id: "research",
        name: "情报部",
        workspace: "~/.openclaw/workspace-research",
        model: {
          primary: "deepseek/deepseek-v3",
          fallbacks: ["deepseek/deepseek-v4-flash"],
        },
        tools: {
          exec: {
            allow: [
              { match: { command: "python" } },
              { match: { command: "curl" } },
              { match: { command: "git", args: ["*"] } },
            ],
          },
        },
      },
      {
        id: "ops",
        name: "运维部",
        workspace: "~/.openclaw/workspace-ops",
        costLimit: { daily: 5, perRequest: 0.3 },
      },
      {
        id: "exec",
        name: "行政部",
        workspace: "~/.openclaw/workspace-exec",
        model: {
          primary: "deepseek/deepseek-v4-flash",
        },
        costLimit: { daily: 2, perRequest: 0.1 },
      },
    ],

    // MCP Servers — 共享服务中心
    mcp: {
      servers: {
        filesystem: {
          transport: "stdio",
          command: "npx",
          args: ["-y", "@modelcontextprotocol/server-filesystem", "./agents/shared/workspace"],
        },
        metamcp: {
          transport: "http",
          url: "http://localhost:12008/sse",
        },
        github: {
          transport: "stdio",
          command: "npx",
          args: ["-y", "@modelcontextprotocol/server-github"],
          env: {
            GITHUB_PERSONAL_ACCESS_TOKEN: "${GITHUB_TOKEN}",
          },
        },
      },
    },
  },

  // ====================================================================
  // Bindings — 路由规则（根级别）
  // ====================================================================
  bindings: [
    {
      agentId: "coding",
      match: {
        channel: "telegram",
      },
    },
    {
      agentId: "research",
      match: {
        channel: "telegram",
      },
    },
    {
      agentId: "ops",
      match: {
        channel: "feishu",
      },
    },
    {
      agentId: "exec",
      match: {
        channel: "feishu",
      },
    },
  ],

  // ====================================================================
  // 通道
  // ====================================================================
  channels: {
    telegram: {
      enabled: true,
      botToken: "${TELEGRAM_BOT_TOKEN}",
      dmPolicy: "pairing",
    },
    feishu: {
      enabled: true,
      appId: "${FEISHU_APP_ID}",
      appSecret: "${FEISHU_APP_SECRET}",
      dmPolicy: "allowlist",
      allowFrom: [],
    },
  },
}
